<div class="container" style="min-height: 80vh; display: flex; flex-direction: column; justify-content: center; align-items: center;">

    <!-- Título de impacto de error con el text-shadow rosa/fucsia de tus h1 -->
    <h1>¡Ups! Algo salió mal</h1>
    <h2 style="color: #FF3366;">Error detectado en el sistema</h2>

    <!-- Contenedor de alerta que ya tienes diseñado en tu CSS -->
    <div class="alert-error-container" style="max-width: 600px; padding: 30px; margin: 20px auto;">
        
        <!-- Icono decorativo estilo glitch/advertencia -->
        <div style="font-size: 3rem; margin-bottom: 15px; color: #FF3366;">⚠️</div>
        
        <!-- Aquí se renderiza la variable dinámica que envías desde Express/Django con Handlebars -->
        <p class="alert-error-text" style="text-transform: none; letter-spacing: normal; font-size: 1.1rem; line-height: 1.6;">
            {{message}}
        </p>
        
    </div>

    <!-- Acciones para que el usuario pueda volver a un lugar seguro -->
    <div class="actions" style="max-width: 400px; margin-top: 20px; gap: 15px;">
        
        <a href="/products" class="nav-link live-btn" style="text-align: center;">
            Volver al Catálogo
        </a>
        
        <!-- Botón alternativo utilizando los estilos de borde rosa/rojo de tu CSS -->
        <a href="javascript:history.back()" class="nav-link" style="text-align: center; border-color: #FF3366; color: #FF3366;">
            Regresar
        </a>
        
    </div>

</div>