<div class="container">

    <h1>Mi carrito</h1>
    <h2>Productos agregados</h2>

    {{#if cart.products.length}}

        <div class="products-grid">

            {{#each cart.products}}

                <article class="product-card">
                    
                    
                    <div class="product-images">
                        <img
                            src="{{this.product.thumbnails.[0]}}"
                            alt="{{this.product.title}}"
                        >
                    </div>

                    
                    <h1>{{this.product.title}}</h1>
                    <h2>Categoría: {{this.product.category}}</h2>

                    <p>
                        <strong>Precio:</strong>
                        $ {{this.product.price}}
                    </p>

                    <p>
                        <strong>Cantidad:</strong>
                        {{this.quantity}}
                    </p>

                    <p>
                        <strong>Subtotal:</strong>
                        $ {{multiply this.product.price this.quantity}}
                    </p>

                    <div class="actions">
                        <form action="/cart/products/{{this.product._id}}/delete" method="POST" style="width: 100%;">
                           
                            <button type="submit" class="btn-delete">
                                Borrar producto
                            </button>
                        </form>
                    </div>

                </article>

            {{/each}}

        </div>

    {{else}}

        <div class="alert-error-container">
            <p class="alert-error-text">
                El carrito está vacío.
            </p>
        </div>

    {{/if}}

</div>

<div class="container-form">

    <h2>Resumen de compra</h2>

    <p style="font-size: 1.3rem; text-align: center; margin-bottom: 20px;">
        <strong>Total:</strong>
        <span style="color: #00E5FF; font-weight: bold;">$ {{total}}</span>
    </p>

    <div class="actions">

        <a
            href="/products"
            class="nav-link live-btn"
        >
            Seguir comprando
        </a>

        <form action="/carts/{{cart._id}}/clear" method="POST" style="flex: 1;">
           
            <button type="submit" class="btn-delete" style="width: 100%;">
                Vaciar Carrito
            </button>
        </form>

    </div>

</div>